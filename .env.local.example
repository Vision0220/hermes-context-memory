# .env.local — 本地 API 密钥配置
# 此文件不会被提交到 Git（已在 .gitignore 中）
# 复制为 .env.local 后填入你的 API 密钥

# VLM 模型配置
HCM_VLM_BASE_URL=https://your-api-url/v1
HCM_VLM_API_KEY=sk-your-api-key-here
HCM_VLM_MODEL=qwen/qwen3.6-35b-a3b
HCM_VLM_ENABLED=true

# Embedding 模型配置
HCM_EMBEDDING_BASE_URL=https://your-api-url/v1
HCM_EMBEDDING_API_KEY=sk-your-api-key-here
HCM_EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b
HCM_EMBEDDING_ENABLED=true

# 服务配置（可选，有默认值）
# HCM_SERVER_PORT=1833
# HCM_SERVER_HOST=127.0.0.1
# HCM_CAPTURE_INTERVAL=15
# HCM_CAPTURE_ENABLED=true
